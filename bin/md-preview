#!/bin/bash
# Markdown preview daemon launcher for yazi
# 每文件独立实例：不同 md 文件互不干扰；同一文件再次预览替换自己的旧实例。
# 每个实例由独立 watchdog 看护，浏览器 tab 关闭后自动清理，防止僵尸进程。

set -u

FILE="${1:-}"

# Default instance id placeholder. Real id is derived from ABS_FILE in the
# launch path; --watchdog / --stop-all override these explicitly.
_ID="default"
PID_FILE="/tmp/md-preview.${_ID}.pid"
WATCHDOG_PID_FILE="/tmp/md-preview.${_ID}.watchdog.pid"
LOG_FILE="/tmp/md-preview.${_ID}.log"
SOCK_FILE="/tmp/md-preview.${_ID}.sock"

STARTUP_GRACE_SEC="${MD_PREVIEW_STARTUP_GRACE_SEC:-90}"
IDLE_GRACE_SEC="${MD_PREVIEW_IDLE_GRACE_SEC:-15}"
POLL_SEC="${MD_PREVIEW_POLL_SEC:-2}"
DEBUG_MODE="${MD_PREVIEW_DEBUG:-0}"

NVIM_BIN="/opt/homebrew/bin/nvim"
MKDP_APP_DIR="$HOME/.local/share/nvim/lazy/markdown-preview.nvim/app"
MKDP_BIN="$MKDP_APP_DIR/bin/markdown-preview-macos-arm64"

if [ ! -x "$NVIM_BIN" ]; then
    NVIM_BIN="$(command -v nvim 2>/dev/null || true)"
fi

if [[ "$0" == */* ]]; then
    SELF_PATH="$0"
else
    SELF_PATH="$(command -v "$0" 2>/dev/null || echo "$0")"
fi

timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

log_line() {
    printf '[%s] %s\n' "$(timestamp)" "$*" >> "$LOG_FILE"
}

is_running_pid() {
    local pid="${1:-}"
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

read_pid_file() {
    local file="$1"
    local pid
    [ -f "$file" ] || return 1
    pid="$(cat "$file" 2>/dev/null | tr -cd '0-9')"
    [ -n "$pid" ] || return 1
    printf '%s\n' "$pid"
}

cleanup_files() {
    rm -f "$PID_FILE" "$WATCHDOG_PID_FILE" "$SOCK_FILE"
}

terminate_main_process() {
    local pid="$1"
    if ! is_running_pid "$pid"; then
        return 0
    fi

    if [ -S "$SOCK_FILE" ] && [ -x "$NVIM_BIN" ]; then
        "$NVIM_BIN" --server "$SOCK_FILE" --remote-send "<Esc>:silent! MarkdownPreviewStop<CR>:qa!<CR>" >/dev/null 2>&1 || true
        sleep 0.3
    fi

    kill "$pid" 2>/dev/null || true
    sleep 0.2
    if is_running_pid "$pid"; then
        kill -9 "$pid" 2>/dev/null || true
    fi
}

stop_running() {
    local main_pid watchdog_pid

    if watchdog_pid="$(read_pid_file "$WATCHDOG_PID_FILE")"; then
        kill "$watchdog_pid" 2>/dev/null || true
        rm -f "$WATCHDOG_PID_FILE"
    fi

    if main_pid="$(read_pid_file "$PID_FILE")"; then
        terminate_main_process "$main_pid"
    fi

    cleanup_files
}

print_failure_and_log() {
    echo "Preview failed to start"
    if [ -f "$LOG_FILE" ]; then
        echo "---- md-preview log ----"
        tail -n 120 "$LOG_FILE"
    fi
}

ensure_mkdp_runtime() {
    if [ ! -d "$MKDP_APP_DIR" ]; then
        echo "Preview failed to start: markdown-preview.nvim app dir not found: $MKDP_APP_DIR"
        return 1
    fi

    # Prebuilt mkdp binary may exit immediately on newer environments.
    # Force node runtime path for stable behavior.
    if [ -x "$MKDP_BIN" ]; then
        chmod -x "$MKDP_BIN" 2>/dev/null || true
    fi

    if [ ! -f "$MKDP_APP_DIR/node_modules/tslib/package.json" ]; then
        if ! command -v npm >/dev/null 2>&1; then
            echo "Preview failed to start: npm not found (required by markdown-preview.nvim)"
            return 1
        fi
        log_line "Installing markdown-preview.nvim node dependencies"
        if ! (cd "$MKDP_APP_DIR" && npm install --no-audit --no-fund >>"$LOG_FILE" 2>&1); then
            echo "Preview failed to start: npm install failed for markdown-preview.nvim"
            return 1
        fi
    fi

    return 0
}

watchdog_main() {
    local main_pid="$1"
    local started_at="$2"
    local seen_client=0
    local last_active="$started_at"
    local now raw state

    log_line "[watchdog] started pid=$main_pid startup_grace=${STARTUP_GRACE_SEC}s idle_grace=${IDLE_GRACE_SEC}s"

    while is_running_pid "$main_pid"; do
        now="$(date +%s)"
        # Try to query nvim. If it fails, don't assume 0 clients immediately.
        raw="$("$NVIM_BIN" --server "$SOCK_FILE" --remote-expr 'exists("g:mkdp_clients_active") ? g:mkdp_clients_active : 0' 2>/dev/null || echo "QUERY_FAILED")"
        state="$(printf '%s' "$raw" | tr -d '\r\n[:space:]')"
        
        # If query failed, check if node server is still alive as a backup heartbeat
        if [ "$state" = "QUERY_FAILED" ] || [ -z "$state" ]; then
            if pgrep -f "markdown-preview.nvim/app/index.js" >/dev/null; then
                state=1 # Assume active if node is running
                log_line "[watchdog][debug] RPC failed but Node server alive, assuming active"
            else
                state=0
            fi
        fi

        if [ "$DEBUG_MODE" = "1" ]; then
            log_line "[watchdog][debug] state=$state seen_client=$seen_client now=$now last_active=$last_active"
        fi

        case "$state" in
            1)
                seen_client=1
                last_active="$now"
                ;;
            0)
                if [ "$seen_client" -eq 1 ]; then
                    if [ $((now - last_active)) -ge "$IDLE_GRACE_SEC" ]; then
                        log_line "[watchdog] browser disconnected for ${IDLE_GRACE_SEC}s, stopping preview"
                        terminate_main_process "$main_pid"
                        cleanup_files
                        exit 0
                    fi
                else
                    if [ $((now - started_at)) -ge "$STARTUP_GRACE_SEC" ]; then
                        log_line "[watchdog] no browser connected in ${STARTUP_GRACE_SEC}s, stopping preview"
                        terminate_main_process "$main_pid"
                        cleanup_files
                        exit 0
                    fi
                fi
                ;;
            *)
                # Server may still be booting up, ignore transient values.
                ;;
        esac

        sleep "$POLL_SEC"
    done

    cleanup_files
    log_line "[watchdog] preview process exited, cleanup complete"
}

# Watchdog mode: --watchdog <pid> <started_at> <instance_id>
if [ "$FILE" = "--watchdog" ]; then
    WATCH_PID="${2:-}"
    STARTED_AT="${3:-$(date +%s)}"
    WD_ID="${4:-global}"
    if [ -z "$WATCH_PID" ]; then
        exit 1
    fi
    # Override file paths with the correct instance ID
    PID_FILE="/tmp/md-preview.${WD_ID}.pid"
    WATCHDOG_PID_FILE="/tmp/md-preview.${WD_ID}.watchdog.pid"
    LOG_FILE="/tmp/md-preview.${WD_ID}.log"
    SOCK_FILE="/tmp/md-preview.${WD_ID}.sock"
    watchdog_main "$WATCH_PID" "$STARTED_AT"
    exit 0
fi

# Stop command: with per-file instances there is no "current" — stop everything.
if [ "$FILE" = "--stop-all" ] || [ "$FILE" = "stop" ] || [ "$FILE" = "-s" ]; then
    for pf in /tmp/md-preview.*.pid; do
        [ -f "$pf" ] || continue
        id="$(echo "$pf" | sed 's|/tmp/md-preview\.\(.*\)\.pid|\1|')"
        PID_FILE="/tmp/md-preview.${id}.pid"
        WATCHDOG_PID_FILE="/tmp/md-preview.${id}.watchdog.pid"
        SOCK_FILE="/tmp/md-preview.${id}.sock"
        stop_running
    done
    echo "All previews stopped"
    exit 0
fi

# Patch the plugin's routes.js to support both /page/1 and /1 (Next.js client-side routing)
# This is idempotent and backward compatible.
patch_routes() {
    local routes_file="$MKDP_APP_DIR/routes.js"
    if [ ! -f "$routes_file" ]; then
        log_line "[patch] routes.js not found at $routes_file"
        return
    fi
    # Use perl for more reliable regex replacement on macOS/Linux
    if grep -q '/\\/page\\/\\d+/' "$routes_file"; then
        log_line "[patch] applying route compatibility patch to $routes_file"
        perl -i -pe 's|/\\/page\\/\\d+/|/\\/(page\\/)?\\d+/|g' "$routes_file"
    else
        log_line "[patch] routes.js already patched or modified, skipping"
    fi
}

if [ -z "$FILE" ]; then
    echo "Usage: md-preview <file.md>"
    echo "       md-preview stop"
    exit 1
fi

if [ -z "$NVIM_BIN" ] || [ ! -x "$NVIM_BIN" ]; then
    echo "Preview failed to start: nvim not found"
    exit 1
fi

# Resolve absolute path and switch to file directory for relative assets.
ABS_FILE="$(cd "$(dirname "$FILE")" && pwd)/$(basename "$FILE")"
FILE_DIR="$(dirname "$ABS_FILE")"

if [ ! -f "$ABS_FILE" ]; then
    echo "Preview failed to start: file not found: $ABS_FILE"
    exit 1
fi

cd "$FILE_DIR" || exit 1

# Per-file instance id: stable hash of the absolute path. Same file replaces
# its own previous preview; different files coexist as independent instances.
_ID="$(printf '%s' "$ABS_FILE" | shasum -a 1 | awk '{print substr($1,1,12)}')"
PID_FILE="/tmp/md-preview.${_ID}.pid"
WATCHDOG_PID_FILE="/tmp/md-preview.${_ID}.watchdog.pid"
LOG_FILE="/tmp/md-preview.${_ID}.log"
SOCK_FILE="/tmp/md-preview.${_ID}.sock"

stop_running >/dev/null 2>&1 || true
rm -f "$SOCK_FILE"
: > "$LOG_FILE"
log_line "Launching markdown preview for: $ABS_FILE"

if ! ensure_mkdp_runtime; then
    print_failure_and_log
    exit 1
fi

patch_routes

nohup "$NVIM_BIN" --listen "$SOCK_FILE" --headless -n "$ABS_FILE" \
    -c "let g:mkdp_auto_close = 0" \
    -c "let g:mkdp_browser_close_preview = 0" \
    -c "set autoread" \
    -c "call timer_start(3000, {-> execute('silent! checktime')}, {'repeat': -1})" \
    -c "silent! MarkdownPreview" \
    >>"$LOG_FILE" 2>&1 < /dev/null &
NEW_PID=$!

sleep 0.8
if ! is_running_pid "$NEW_PID"; then
    print_failure_and_log
    exit 1
fi

echo "$NEW_PID" > "$PID_FILE"
STARTED_AT="$(date +%s)"

nohup "$SELF_PATH" --watchdog "$NEW_PID" "$STARTED_AT" "$_ID" >>"$LOG_FILE" 2>&1 < /dev/null &
WATCHDOG_PID=$!
echo "$WATCHDOG_PID" > "$WATCHDOG_PID_FILE"

sleep 0.2
if ! is_running_pid "$WATCHDOG_PID"; then
    log_line "[watchdog] failed to start"
fi

echo "Preview started (PID: $NEW_PID, watchdog: $WATCHDOG_PID)"
echo "Log: $LOG_FILE"
echo "Run 'md-preview stop' to close"
